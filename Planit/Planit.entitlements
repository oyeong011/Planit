<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 비샌드박스 앱: app-sandbox=false이면 network.client/server/files.user-selected는
         의미 없음. 남겨두면 macOS Sonoma TCC가 Photos/Music/네트워크볼륨 권한을
         선제적으로 요청하는 부작용 발생 → 제거 -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <!-- Hardened Runtime: calendars/reminders는 실제로 사용하므로 유지 -->
    <key>com.apple.security.personal-information.calendars</key>
    <true/>
    <key>com.apple.security.personal-information.reminders</key>
    <true/>

    <!-- ⚠️ iOS 공유용 entitlement들은 macOS App ID (com.oy.planit) 에
         Apple Developer Console 에서 capability 등록 전까지는 포함 금지.
         등록 없이 넣으면 런타임 validator가 SIGKILL (v0.4.5 사고 사례, exit 137).
         registration 완료 후 application-groups / keychain-access-groups /
         icloud-container-identifiers / icloud-services 를 다시 추가할 것. -->
</dict>
</plist>
